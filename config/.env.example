# Copier vers .env et remplir les valeurs.
# .env est dans .gitignore — ne jamais commit les secrets.

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MODEL_DEEP=claude-sonnet-4-6

# === Email (choisir UN provider) ===

# Option A : Mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_FROM=veille@mg.example.com

# Option B : Resend (recommandé pour DX)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=veille@yourdomain.com

# Option C : SMTP Gmail (App Password requis)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youremail@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=youremail@gmail.com

# === Destinataire des digests ===
DIGEST_RECIPIENT=franck@example.com

# === Storage ===
DB_PATH=./data/veille.db

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./data/veille.log
